generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum RoomStatus {
  AVAILABLE
  MAINTENANCE
  INACTIVE
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  timezone  String   @default("UTC")
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings  Booking[]

  @@map("users")
}

model Hotel {
  id          String   @id @default(uuid())
  name        String
  description String?
  address     String
  city        String
  country     String
  timezone    String   @default("UTC")
  images      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roomTypes   RoomType[]

  @@map("hotels")
}

model RoomType {
  id            String   @id @default(uuid())
  hotelId       String
  name          String
  description   String?
  pricePerNight Decimal  @db.Decimal(10, 2)
  maxGuests     Int
  amenities     String[]
  images        String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  hotel         Hotel    @relation(fields: [hotelId], references: [id])
  rooms         Room[]

  @@map("room_types")
}

model Room {
  id         String     @id @default(uuid())
  roomTypeId String
  hotelId    String
  number     String
  floor      Int
  status     RoomStatus @default(AVAILABLE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  roomType   RoomType   @relation(fields: [roomTypeId], references: [id])
  bookings   Booking[]

  @@unique([hotelId, number])
  @@map("rooms")
}

model Booking {
  id           String        @id @default(uuid())
  userId       String
  roomId       String
  checkIn      DateTime      @db.Date
  checkOut     DateTime      @db.Date
  totalPrice   Decimal       @db.Decimal(10, 2)
  guestCount   Int
  status       BookingStatus @default(PENDING)
  specialNotes String?
  reminderSent Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  room         Room          @relation(fields: [roomId], references: [id])

  @@map("bookings")
}
